---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import heroCover from "../assets/images/book/hero-cover.png";
import authorPhoto from "../assets/images/book/daniel-cabrera-author.jpeg";

const bookPrice = "$399 MXN";
const checkoutSlug = "nunca-digas-no-tengo-dinero";
---

<Layout
  title='Nunca Digas: "No Tengo Dinero" | Libro de Daniel Cabrera'
  description='Landing del libro Nunca digas: "No tengo dinero" de Daniel Cabrera dentro del sitio de Carobra.'
>
  <section class="relative overflow-hidden bg-carobra-light-bg">
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_12%_20%,rgba(255,255,255,0.88),transparent_24%),radial-gradient(circle_at_86%_18%,rgba(0,169,224,0.14),transparent_22%),linear-gradient(135deg,#e6f4fa_0%,#d5eef8_38%,#eaf8fc_100%)]"
    >
    </div>
    <div
      class="absolute inset-x-0 bottom-0 h-24 bg-[linear-gradient(180deg,rgba(230,244,250,0),rgba(255,255,255,0.55))]"
    >
    </div>
    <div class="mx-auto max-w-7xl px-4 py-36 sm:px-6 sm:py-40 lg:px-8 lg:py-48">
      <div
        class="relative grid gap-16 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,0.82fr)] lg:items-center lg:gap-16"
      >
        <div class="text-center lg:text-left">
          <h1
            class="book-hero-title mx-auto max-w-4xl text-[3.6rem] text-transparent bg-[linear-gradient(180deg,#3da9df_0%,#1f7fc6_45%,#004e8a_100%)] bg-clip-text sm:text-[5rem] lg:mx-0 lg:text-[6.2rem]"
          >
            Nunca digas:
            <span class="block">"No tengo</span>
            <span class="block">dinero"</span>
          </h1>

          <div
            class="mt-7 mx-auto max-w-xl space-y-4 text-carobra-dark/82 lg:mx-0"
          >
            <p class="paragraph-2 sm:text-[1.02rem]">
              Descubre una historia de éxito y autenticidad con una mentalidad
              de riqueza centrada en las personas.
            </p>
          </div>

          <div
            class="mt-10 flex flex-col gap-3 sm:flex-row sm:justify-center lg:justify-start"
          >
            <button
              type="button"
              data-book-checkout
              data-book-slug={checkoutSlug}
              class="btn-primary inline-flex min-h-14 items-center justify-center rounded-lg bg-carobra-primary px-8 text-white transition-colors hover:bg-carobra-dark"
            >
              Comprar libro
            </button>
            <a
              href="#autor"
              class="btn-secondary inline-flex min-h-14 items-center justify-center rounded-lg border-2 border-carobra-primary/30 bg-white/60 px-8 text-carobra-primary transition-colors hover:bg-white hover:text-carobra-dark"
            >
              Conocer el autor
            </a>
          </div>
        </div>

        <div class="relative flex justify-center lg:justify-end">
          <div
            class="absolute top-6 right-6 h-52 w-52 rounded-full bg-white/40 blur-3xl"
          >
          </div>
          <div
            class="absolute bottom-6 left-6 h-48 w-48 rounded-full bg-carobra-light/28 blur-3xl"
          >
          </div>
          <div
            class="relative w-full max-w-[27rem] sm:max-w-[33rem] lg:max-w-[38rem]"
          >
            <div
              class="absolute -inset-6 rounded-[3rem] bg-[radial-gradient(circle_at_50%_50%,rgba(0,169,224,0.24),rgba(0,169,224,0)_72%)] blur-3xl"
            >
            </div>
            <div
              class="absolute inset-x-10 inset-y-10 rounded-[2.4rem] bg-[linear-gradient(145deg,rgba(10,35,66,0.22),rgba(0,78,138,0.14)_52%,rgba(0,169,224,0.10))] blur-2xl"
            >
            </div>
            <div
              class="relative translate-x-1 rotate-[1.4deg] overflow-hidden rounded-[2rem] shadow-[0_34px_80px_rgba(0,78,138,0.28)] sm:translate-x-2 lg:rotate-[1.8deg]"
            >
              <Image
                src={heroCover}
                alt='Daniel Cabrera en el arte principal del libro "Nunca digas: no tengo dinero"'
                class="relative z-10 h-[24rem] w-full object-cover object-center sm:h-[29rem] lg:h-[33rem]"
                loading="eager"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section
    class="relative overflow-hidden bg-carobra-light-bg py-18 sm:py-20 lg:py-24"
  >
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_18%_18%,rgba(255,255,255,0.72),transparent_24%),radial-gradient(circle_at_82%_68%,rgba(0,169,224,0.12),transparent_26%),linear-gradient(180deg,rgba(255,255,255,0.18),rgba(255,255,255,0))]"
    >
    </div>
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="relative">
        <div>
          <h2
            class="max-w-4xl text-[3rem] font-black uppercase leading-[0.88] tracking-[-0.06em] text-transparent bg-[linear-gradient(180deg,#5b88d2_0%,#275eae_52%,#143a75_100%)] bg-clip-text sm:text-[4.2rem] lg:text-[5.3rem]"
          >
            Una historia de éxito y autenticidad.
          </h2>
          <p
            class="mt-8 max-w-4xl paragraph-2 text-[#31527f] sm:text-[1.08rem] sm:leading-8"
          >
            "Nunca digas: 'no tengo dinero'" es un libro para líderes,
            emprendedores y profesionales que buscan dejar de reaccionar y
            comenzar a construir mejores hábitos, mejores equipos y mejores
            resultados.
          </p>
          <p
            class="mt-4 max-w-4xl paragraph-2 text-[#31527f] sm:text-[1.08rem] sm:leading-8"
          >
            Un recorrido honesto acerca de lo que significa hacer empresa,
            formar personas y crecer de manera consistente, disfrutando del
            proceso y manteniendo la integridad como motor.
          </p>
        </div>
      </div>

      <div class="relative mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3 lg:gap-7">
        <article
          class="group relative flex h-full flex-col overflow-hidden rounded-[1.9rem] border border-carobra-primary/10 bg-white/78 p-6 shadow-[0_18px_40px_rgba(0,78,138,0.09)] backdrop-blur-sm transition duration-300 hover:-translate-y-1 hover:shadow-[0_24px_52px_rgba(0,78,138,0.14)] sm:p-7 lg:p-8"
        >
          <div class="absolute inset-x-8 top-0 h-px bg-carobra-primary/25"></div>
          <div class="flex items-center justify-between">
            <div
              class="flex h-11 w-11 items-center justify-center rounded-xl bg-carobra-primary/8 text-carobra-primary"
            >
              <svg
                viewBox="0 0 24 24"
                class="h-6 w-6 fill-current"
                aria-hidden="true"
              >
                <path
                  d="M12 3 3 8v2h18V8l-9-5Zm-7 9v6H3v2h18v-2h-2v-6h-2v6h-3v-6h-2v6H9v-6H7Z"
                ></path>
              </svg>
            </div>
            <span class="text-sm font-bold tracking-[0.18em] text-carobra-primary/35"
              >01</span
            >
          </div>
          <h3
            class="mt-6 text-[1.65rem] font-bold leading-[1.15] tracking-[-0.035em] text-[#1f4e92] lg:min-h-[7.25rem]"
          >
            Cambia la forma en la que piensas.
          </h3>
          <div class="mt-5 h-px w-12 bg-carobra-primary/25"></div>
          <p class="mt-5 paragraph-2 text-[0.98rem] leading-7 text-[#4b6287]">
            Todo cambio comienza en la mente. Las creencias que repetimos todos
            los días determinan las decisiones que tomamos y, en consecuencia,
            los resultados que obtenemos. Aprender a cuestionarlas y
            sustituirlas por pensamientos de posibilidad es el primer paso para
            construir una vida de mayor prosperidad.
          </p>
        </article>

        <article
          class="group relative flex h-full flex-col overflow-hidden rounded-[1.9rem] border border-carobra-primary/10 bg-white/78 p-6 shadow-[0_18px_40px_rgba(0,78,138,0.09)] backdrop-blur-sm transition duration-300 hover:-translate-y-1 hover:shadow-[0_24px_52px_rgba(0,78,138,0.14)] sm:p-7 lg:p-8"
        >
          <div class="absolute inset-x-8 top-0 h-px bg-carobra-primary/25"></div>
          <div class="flex items-center justify-between">
            <div
              class="flex h-11 w-11 items-center justify-center rounded-xl bg-carobra-primary/8 text-carobra-primary"
            >
              <svg
                viewBox="0 0 24 24"
                class="h-6 w-6 fill-none stroke-current stroke-2"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="m4 16 5-5 4 4 7-7"></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15 8h5v5"></path>
              </svg>
            </div>
            <span class="text-sm font-bold tracking-[0.18em] text-carobra-primary/35"
              >02</span
            >
          </div>
          <h3
            class="mt-6 text-[1.65rem] font-bold leading-[1.15] tracking-[-0.035em] text-[#1f4e92] lg:min-h-[7.25rem]"
          >
            Desarrolla las habilidades que transforman tu vida.
          </h3>
          <div class="mt-5 h-px w-12 bg-carobra-primary/25"></div>
          <p class="mt-5 paragraph-2 text-[0.98rem] leading-7 text-[#4b6287]">
            El crecimiento no ocurre por casualidad, sino por la suma de
            pequeñas acciones realizadas con disciplina y constancia. A través
            de experiencias reales y aprendizajes obtenidos en el mundo de las
            ventas y el emprendimiento, descubrirás cómo desarrollar habilidades
            que impulsan tanto tu desarrollo personal como profesional.
          </p>
        </article>

        <article
          class="group relative flex h-full flex-col overflow-hidden rounded-[1.9rem] border border-carobra-primary/10 bg-white/78 p-6 shadow-[0_18px_40px_rgba(0,78,138,0.09)] backdrop-blur-sm transition duration-300 hover:-translate-y-1 hover:shadow-[0_24px_52px_rgba(0,78,138,0.14)] sm:p-7 lg:p-8 md:col-span-2 lg:col-span-1"
        >
          <div class="absolute inset-x-8 top-0 h-px bg-carobra-primary/25"></div>
          <div class="flex items-center justify-between">
            <div
              class="flex h-11 w-11 items-center justify-center rounded-xl bg-carobra-primary/8 text-carobra-primary"
            >
              <svg
                viewBox="0 0 24 24"
                class="h-6 w-6 fill-current"
                aria-hidden="true"
              >
                <path
                  d="M12 2 5 5v6c0 5 3.4 9.7 7 11 3.6-1.3 7-6 7-11V5l-7-3Zm0 5a3 3 0 1 1 0 6 3 3 0 0 1 0-6Zm0 12c-1.9-.9-3.8-3-4.8-5.7.9-.8 2.1-1.3 3.4-1.3h2.8c1.3 0 2.5.5 3.4 1.3C15.8 16 13.9 18.1 12 19Z"
                ></path>
              </svg>
            </div>
            <span class="text-sm font-bold tracking-[0.18em] text-carobra-primary/35"
              >03</span
            >
          </div>
          <h3
            class="mt-6 text-[1.65rem] font-bold leading-[1.15] tracking-[-0.035em] text-[#1f4e92] lg:min-h-[7.25rem]"
          >
            Construye una vida con más opciones y propósito.
          </h3>
          <div class="mt-5 h-px w-12 bg-carobra-primary/25"></div>
          <p class="mt-5 paragraph-2 text-[0.98rem] leading-7 text-[#4b6287]">
            La verdadera libertad no consiste únicamente en tener más dinero,
            sino en contar con opciones. Cuando desarrollas una mentalidad de
            abundancia, aprendes a generar valor y construyes diversas fuentes
            de ingreso, dejas de trabajar solo para sobrevivir y comienzas a
            diseñar la vida que realmente deseas vivir.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section id="autor" class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div
        class="grid gap-10 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-center"
      >
        <div
          class="relative aspect-[4/3] overflow-hidden rounded-[2rem] border border-carobra-primary/15 bg-slate-100 shadow-[0_22px_55px_rgba(10,35,66,0.16)]"
        >
          <Image
            src={authorPhoto}
            alt='Daniel Cabrera presentando su libro "Nunca digas: no tengo dinero"'
            class="h-full w-full object-cover object-[43%_center]"
            widths={[480, 768, 1264]}
            sizes="(min-width: 1024px) 42vw, 100vw"
            quality={95}
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="text-center">
          <h2
            class="mt-2 mb-8 text-[12rem] font-bold uppercase leading-[0.9] text-transparent bg-[linear-gradient(135deg,#0A2342_0%,#004E8A_100%)] bg-clip-text sm:text-[4.2rem]"
          >
            Daniel Cabrera
          </h2>
          <p class="mt-6 max-w-2xl paragraph-2 text-gray-700">
            Daniel Cabrera es empresario, autor y fundador de CAROBRA,
            corporativo financiero con presencia nacional y más de 15 años de
            trayectoria transformando vidas a través de las ventas, el liderazgo
            y la educación financiera. Ingeniero en Sistemas y Egresado del
            Programa de Perfeccionamiento Directivo del IPADE Business School,
            ha dedicado su carrera a formar líderes y construir equipos de alto
            desempeño.
          </p>
          <p class="mt-6 max-w-2xl paragraph-2 text-gray-700">
            En su Libro comparte la historia, aprendizajes y principios que lo
            llevaron de escuchar constantemente la frase “no tengo dinero” a
            construir una organización que impacta a miles de personas,
            demostrando que las ventas pueden convertirse en una herramienta
            para cambiar destinos y crear prosperidad
          </p>
        </div>
      </div>
    </div>
  </section>

  <section
    id="compra"
    class="relative overflow-hidden bg-carobra-light-bg py-20 sm:py-24 lg:py-28"
  >
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_14%_22%,rgba(255,255,255,0.82),transparent_24%),radial-gradient(circle_at_78%_52%,rgba(0,169,224,0.18),transparent_24%),linear-gradient(180deg,rgba(255,255,255,0.08),rgba(255,255,255,0))]"
    >
    </div>
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div
        class="relative grid gap-14 lg:grid-cols-[minmax(0,1.15fr)_minmax(18rem,22rem)] lg:items-start lg:gap-20 xl:gap-28"
      >
        <div class="text-center lg:text-left">
          <p
            class="text-sm font-semibold uppercase tracking-[0.28em] text-carobra-primary"
          >
            Consigue tu ejemplar
          </p>
          <h2
            class="book-hero-title mx-auto mt-4 max-w-6xl text-[4.8rem] text-transparent bg-[linear-gradient(180deg,#5b88d2_0%,#275eae_52%,#143a75_100%)] bg-clip-text sm:text-[6.4rem] lg:mx-0 lg:text-[8.2rem] xl:text-[9rem]"
          >
            Resuelve la Ecuación
          </h2>
          <p
            class="mx-auto mt-7 max-w-3xl paragraph-2 text-[1.14rem] leading-9 text-[#3a557c] sm:text-[1.2rem] lg:mx-0"
          >
            Una lectura directa para líderes, emprendedores y profesionales que
            quieren pensar mejor, decidir mejor y construir mejores resultados.
          </p>
        </div>

        <div class="relative text-center lg:pl-10 lg:text-right">
          <div
            class="absolute left-0 top-1 hidden h-40 w-px bg-[linear-gradient(180deg,rgba(39,94,174,0),rgba(39,94,174,0.28),rgba(39,94,174,0))] lg:block"
          >
          </div>
          <p
            class="text-xs font-semibold uppercase tracking-[0.3em] text-carobra-primary/70"
          >
            Precio
          </p>
          <p
            class="mt-3 text-[4rem] font-black leading-none tracking-[-0.07em] text-[#103b75] sm:text-[4.9rem] lg:text-[5.2rem]"
          >
            {bookPrice}
          </p>
          <button
            type="button"
            data-book-checkout
            data-book-slug={checkoutSlug}
            class="btn-primary mt-7 inline-flex min-h-14 items-center justify-center rounded-xl bg-carobra-primary px-12 text-white transition-colors hover:bg-carobra-dark"
          >
            Comprar ahora
          </button>
          <p
            id="book-checkout-status"
            class="mt-4 min-h-6 paragraph-2 text-center text-sm text-[#4b6287] lg:text-right"
            aria-live="polite"
          >
            Pago seguro con Stripe.
          </p>
          <p class="mt-2 paragraph-2 text-center text-sm text-[#4b6287] lg:text-right">
            En caso de dudas, puedes contactarnos en
            <a
              href="mailto:administracion@kingala.com"
              class="font-semibold text-carobra-primary underline decoration-carobra-primary/30 underline-offset-4 transition-colors hover:text-carobra-dark"
            >
              administracion@kingala.com
            </a>.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  const checkoutButtons = document.querySelectorAll("[data-book-checkout]");
  const statusNode = document.querySelector("#book-checkout-status");

  function setStatus(message, isError = false) {
    if (!statusNode) {
      return;
    }

    statusNode.textContent = message;
    statusNode.classList.toggle("text-red-600", isError);
    statusNode.classList.toggle("text-[#4b6287]", !isError);
  }

  async function handleCheckoutClick(event) {
    const button = event.currentTarget;
    const originalLabel = button.textContent;

    button.disabled = true;
    button.textContent = "Conectando...";
    button.classList.add("opacity-80");
    setStatus("Estamos conectando tu compra con Stripe.");

    try {
      const response = await fetch("/api/checkout/create-session/", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          bookSlug: button.dataset.bookSlug,
          quantity: 1,
        }),
      });

      const payload = await response.json().catch(() => null);

      if (!response.ok || !payload?.checkoutUrl) {
        throw new Error(
          payload?.error || "No fue posible iniciar el checkout.",
        );
      }

      window.location.href = payload.checkoutUrl;
    } catch (error) {
      console.error(error);
      setStatus(
        error instanceof Error
          ? error.message
          : "No fue posible iniciar la compra en este momento.",
        true,
      );
      button.disabled = false;
      button.textContent = originalLabel;
      button.classList.remove("opacity-80");
    }
  }

  checkoutButtons.forEach((button) => {
    button.addEventListener("click", handleCheckoutClick);
  });
</script>
